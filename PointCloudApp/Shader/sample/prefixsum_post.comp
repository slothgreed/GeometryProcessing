layout(std430, binding = 0) buffer Output {
    uint outputData[];
};

layout(std430, binding = 1) buffer BlockSum {
	uint blockSum[];
};

uniform int u_num;

void main() {
    int gid = int(gl_GlobalInvocationID.x);
	int blockID = int(gl_WorkGroupID.x);
    // Load input to shared memory
	if(gid >= u_num){ return;}

    outputData[gid] += blockSum[blockID];
}